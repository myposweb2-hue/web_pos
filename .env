# Database Configuration
# SQLite (default): sqlite:///pos_dev.db
# PostgreSQL: postgresql://username:password@localhost:5432/db_name
DATABASE_URL=postgresql://pos_user:secure_password@localhost:5432/mypos_db

# Flask Configuration
FLASK_ENV=development
SECRET_KEY=your-secret-key-change-in-production

# Mail Configuration (optional)
MAIL_SERVER=localhost
MAIL_PORT=1025
MAIL_USE_TLS=False
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=no-reply@localhost
