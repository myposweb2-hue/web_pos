# POS System Configuration

# Flask Environment
FLASK_ENV=development
FLASK_APP=run.py

# Database URL
# For SQLite: sqlite:///pos.db
# For PostgreSQL: postgresql://user:password@localhost/pos_db
DATABASE_URL=sqlite:///pos.db

# Secret Key (change in production)
SECRET_KEY=your-secret-key-change-in-production

# Twilio Configuration (optional, for WhatsApp notifications)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# Email Configuration (optional, for receipt sending)
# For local development using MailHog (recommended):
# MAIL_SERVER=localhost
# MAIL_PORT=1025
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_DEFAULT_SENDER=no-reply@localhost

# For production, set your real SMTP server settings:
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=your-email@gmail.com
# MAIL_PASSWORD=your-app-password
# MAIL_DEFAULT_SENDER=your-email@gmail.com

# Application Settings
APP_NAME=POS System Web
DEBUG=True
TESTING=False
