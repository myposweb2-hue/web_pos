# ============================================
# PRODUCTION ENVIRONMENT CONFIGURATION
# Copy this to .env and edit with your values
# ============================================

# Flask Settings
FLASK_ENV=production
SECRET_KEY=your-super-secret-key-generate-new-one-with-python-secrets

# Database PostgreSQL
DB_NAME=pos_db
DB_USER=pos_user
DB_PASSWORD=your-very-secure-database-password-change-this

# Email Configuration (Gmail, SendGrid, or your provider)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password
MAIL_DEFAULT_SENDER=noreply@yourdomain.lk

# WhatsApp/SMS Integration (Optional - Twilio)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Domain (Update after pointing DNS)
DOMAIN=yourdomain.lk
DOMAIN_URL=https://yourdomain.lk

# Session
SESSION_PERMANENT=False
PERMANENT_SESSION_LIFETIME=3600

# Upload limits
MAX_CONTENT_LENGTH=16777216
